{
  "ggerganov/llama.cpp": {
    "repo": "https://github.com/ggml-org/llama.cpp",
    "branch": "master",
    "build": "cmake -B build -DGGML_CUDA=ON -DCMAKE_CUDA_ARCHITECTURES=120 -DCMAKE_BUILD_TYPE=Release\ncmake --build build --config Release -j$(nproc)"
  },
  "spiritbuun/buun-llama-cpp": {
    "repo": "https://github.com/spiritbuun/buun-llama-cpp",
    "branch": "master",
    "build": "cmake -B build -DGGML_CUDA=ON -DGGML_NATIVE=ON -DGGML_CUDA_FA=ON -DGGML_CUDA_FA_ALL_QUANTS=ON -DCMAKE_CUDA_ARCHITECTURES=120 -DCMAKE_BUILD_TYPE=Release\n cmake --build build -j$(nproc)"
  },
  "TheTom/llama-cpp-turboquant": {
    "repo": "https://github.com/TheTom/llama-cpp-turboquant",
    "branch": "feature/turboquant-kv-cache",
    "build": "cmake -B build -DGGML_CUDA=ON -DCMAKE_CUDA_ARCHITECTURES=120 -DCMAKE_BUILD_TYPE=Release\ncmake --build build --config Release -j$(nproc)"
  },
  "ikawrakow/ik_llama.cpp": {
    "repo": "https://github.com/ikawrakow/ik_llama.cpp",
    "branch": "main",
    "build": "cmake -B build -DGGML_CUDA=ON -DCMAKE_BUILD_TYPE=Release\ncmake --build build --config Release -j$(nproc)"
  }
}

